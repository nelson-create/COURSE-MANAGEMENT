    "start": "cd backend && npm start",
    "seed": "cd backend && npm run seed:demo"
  },
  "keywords": [
    "mern",
    "course-management",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
